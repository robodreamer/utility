#!/usr/bin/env bash
# Pick a recently used local branch and switch to it.
set -euo pipefail

die() { echo "git-recent: $*" >&2; exit 1; }

have_tty() { [[ -t 0 || -t 1 || -t 2 ]] && [[ -r /dev/tty ]]; }
have_fzf() { command -v fzf >/dev/null 2>&1; }

repo_root() { git rev-parse --show-toplevel 2>/dev/null; }

color_enabled() {
  [[ "${NO_COLOR:-}" == "" ]] && [[ -t 1 || -t 2 ]]
}

c() {
  color_enabled || return 0
  case "$1" in
    reset) printf '\033[0m' ;;
    dim) printf '\033[2m' ;;
    red) printf '\033[31m' ;;
    green) printf '\033[32m' ;;
    yellow) printf '\033[33m' ;;
    blue) printf '\033[34m' ;;
    magenta) printf '\033[35m' ;;
    cyan) printf '\033[36m' ;;
    bold) printf '\033[1m' ;;
  esac
}

branch_exists() {
  git show-ref --verify --quiet "refs/heads/$1"
}

current_branch() {
  git branch --show-current 2>/dev/null || true
}

branch_timestamp() {
  local branch="$1" ts
  ts="$(git reflog show --date=iso-strict --format='%cd' "$branch" 2>/dev/null | head -n 1 || true)"
  if [[ -n "$ts" ]]; then
    printf '%s\n' "$ts"
  else
    git log -1 --date=iso-strict --format='%cd' "$branch" 2>/dev/null || printf '%s\n' "-"
  fi
}

branch_timestamp_record() {
  local branch="$1" ts
  ts="$(git reflog show --date=iso-strict --format='%ct%x09%cd' "$branch" 2>/dev/null | head -n 1 || true)"
  if [[ -n "$ts" ]]; then
    printf '%s\n' "$ts"
  else
    git log -1 --date=iso-strict --format='%ct%x09%cd' "$branch" 2>/dev/null || true
  fi
}

branch_tip() {
  git log -1 --date=relative --format='%h %cr %s' "$1" 2>/dev/null || printf '%s\n' "-"
}

branch_worktree_path() {
  local branch="$1" line path br
  while IFS=$'\t' read -r path br; do
    [[ "$br" == "$branch" ]] || continue
    printf '%s\n' "$path"
    return 0
  done < <(git worktree list --porcelain | awk '
    /^worktree / { path=substr($0, 10); branch="" }
    /^branch refs\/heads\// { branch=substr($0, 19) }
    /^$/ { if (path != "" && branch != "") print path "\t" branch; path=""; branch="" }
    END { if (path != "" && branch != "") print path "\t" branch }
  ')
  return 1
}

resolve_worktree_path() {
  local path="$1"
  if command -v git-park >/dev/null 2>&1; then
    git park go "$path" 2>/dev/null && return 0
  fi
  printf '%s\n' "$path"
}

# Output: branch<TAB>last-used-iso<TAB>tip-summary<TAB>worktree-path-or-empty
recent_branch_rows() {
  local include_current="${1:-0}" current
  local candidates sorted_rows
  current="$(current_branch)"

  local epoch date subject from_branch to_branch branch ts
  candidates="$(
    while IFS=$'\t' read -r epoch date subject; do
      [[ "$subject" =~ ^checkout:\ moving\ from\ (.+)\ to\ (.+)$ ]] || continue
      from_branch="${BASH_REMATCH[1]}"
      to_branch="${BASH_REMATCH[2]}"

      # For branch picking, "last used" is usually the branch you just left.
      for branch in "$from_branch" "$to_branch"; do
        branch_exists "$branch" || continue
        [[ "$include_current" == "1" || "$branch" != "$current" ]] || continue
        printf '%s\t%s\t%s\n' "$epoch" "$date" "$branch"
      done
    done < <(git reflog --date=iso-strict --format='%ct%x09%cd%x09%gs' HEAD 2>/dev/null)

    while IFS= read -r branch; do
      [[ -n "$branch" ]] || continue
      [[ "$include_current" == "1" || "$branch" != "$current" ]] || continue
      ts="$(branch_timestamp_record "$branch")"
      [[ -n "$ts" ]] || continue
      printf '%s\t%s\n' "$ts" "$branch"
    done < <(git for-each-ref --format='%(refname:short)' refs/heads)
  )"

  sorted_rows="$(
    printf '%s\n' "$candidates" |
      awk -F '\t' 'NF >= 3 && $1 ~ /^[0-9]+$/ { print }' |
      sort -rn -k1,1 |
      awk -F '\t' '!seen[$3]++ { print $3 "\t" $2 }'
  )"

  while IFS=$'\t' read -r branch date; do
    [[ -n "$branch" ]] || continue
    printf '%s\t%s\t%s\t%s\n' "$branch" "$date" "$(branch_tip "$branch")" "$(branch_worktree_path "$branch" 2>/dev/null || true)"
  done <<<"$sorted_rows"
}

format_row_plain() {
  local branch="$1" date="$2" tip="$3" wt="$4" current="$5"
  local mark=" "
  [[ "$branch" == "$current" ]] && mark="*"
  if [[ -n "$wt" ]]; then
    printf '%s %-38s  %-25s  %-60s  %s\n' "$mark" "$branch" "$date" "$tip" "worktree: $wt"
  else
    printf '%s %-38s  %-25s  %s\n' "$mark" "$branch" "$date" "$tip"
  fi
}

format_row_color() {
  local branch="$1" date="$2" tip="$3" wt="$4" current="$5"
  local mark=" "
  [[ "$branch" == "$current" ]] && mark="*"
  printf '%s' "$(c yellow)$mark$(c reset) "
  if [[ "$branch" == "$current" ]]; then
    printf '%s' "$(c green)$(c bold)"
  else
    printf '%s' "$(c cyan)"
  fi
  printf '%-38s%s  ' "$branch" "$(c reset)"
  printf '%s%-25s%s  ' "$(c magenta)" "$date" "$(c reset)"
  printf '%s%-60s%s' "$(c dim)" "$tip" "$(c reset)"
  if [[ -n "$wt" ]]; then
    printf '  %s%s%s' "$(c blue)" "worktree: $wt" "$(c reset)"
  fi
  printf '\n'
}

print_rows() {
  local use_color="$1" current branch date tip wt
  current="$(current_branch)"
  while IFS=$'\t' read -r branch date tip wt; do
    [[ -n "$branch" ]] || continue
    if [[ "$use_color" == "1" ]]; then
      format_row_color "$branch" "$date" "$tip" "$wt" "$current"
    else
      format_row_plain "$branch" "$date" "$tip" "$wt" "$current"
    fi
  done
}

pick_branch() {
  local rows current pick
  current="$(current_branch)"
  rows="$(recent_branch_rows 0)"
  [[ -n "$rows" ]] || die "no local branches found"

  if have_fzf && have_tty; then
    pick="$(
      printf '%s\n' "$rows" |
        while IFS=$'\t' read -r branch date tip wt; do
          [[ -n "$branch" ]] || continue
          printf '%s\t' "$branch"
          format_row_color "$branch" "$date" "$tip" "$wt" "$current"
        done |
        fzf --ansi \
          --delimiter=$'\t' \
          --with-nth=2.. \
          --height=18 \
          --layout=reverse \
          --border=rounded \
          --header='git recent: recently used local branches (Enter = switch, Esc = cancel)' \
          --prompt='branch> '
    )" || return 1
    printf '%s\n' "${pick%%$'\t'*}"
    return 0
  fi

  echo "" >&2
  echo "git-recent: recently used local branches" >&2
  echo "(Install fzf for arrow-key selection: https://github.com/junegunn/fzf)" >&2
  echo "" >&2

  local numbered=() i=1 branch date tip wt
  while IFS=$'\t' read -r branch date tip wt; do
    [[ -n "$branch" ]] || continue
    numbered+=("$branch")
    printf '%3d) ' "$i" >&2
    format_row_color "$branch" "$date" "$tip" "$wt" "$current" >&2
    ((i++)) || true
  done <<<"$rows"
  echo "  0) Cancel" >&2

  local n
  have_tty || die "interactive selection needs a terminal"
  read -r -p "Enter number [0=cancel]: " n </dev/tty || return 1
  [[ -n "${n:-}" && "$n" != "0" ]] || return 1
  if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= ${#numbered[@]} )); then
    printf '%s\n' "${numbered[$((n - 1))]}"
  else
    die "invalid selection"
  fi
}

cmd_list() {
  local use_color=1
  if [[ "${1:-}" == "--no-color" ]]; then
    use_color=0
  elif ! color_enabled; then
    use_color=0
  fi
  repo_root >/dev/null || die "not inside a git repository"
  recent_branch_rows 1 | print_rows "$use_color"
}

cmd_pick() {
  repo_root >/dev/null || die "not inside a git repository"
  local branch current root wt dest
  if [[ $# -gt 0 ]]; then
    branch="$1"
    branch_exists "$branch" || die "unknown local branch: $branch"
  else
    branch="$(pick_branch)" || { echo "Cancelled." >&2; return 0; }
  fi
  current="$(current_branch)"
  root="$(repo_root)"
  [[ -n "$branch" ]] || die "could not parse selected branch"
  if [[ "$branch" == "$current" ]]; then
    echo "Already on $branch."
    return 0
  fi
  wt="$(branch_worktree_path "$branch" 2>/dev/null || true)"
  if [[ -n "$wt" && "$wt" != "$root" ]]; then
    dest="$(resolve_worktree_path "$wt")"
    if [[ "${GIT_RECENT_CD_TARGET:-}" == "1" ]]; then
      printf '%s\n' "$dest"
      return 0
    fi
    echo "git-recent: '$branch' is already checked out in another worktree:" >&2
    echo "  $dest" >&2
    echo "" >&2
    echo "A subprocess cannot cd your current shell. Use:" >&2
    printf '  cd %q\n' "$dest" >&2
    echo "" >&2
    echo "Or use the grecent shell function from ~/.bashrc to jump there automatically." >&2
    return 0
  fi
  git switch "$branch"
}

cmd_help() {
  cat <<'EOF'
git-recent - list or switch to recently used local branches

With git-recent on your PATH, Git also accepts:
  git recent

Usage:
  git-recent                 interactive branch picker, then git switch
  git-recent pick            same as default
  git-recent switch BRANCH   switch to BRANCH, or print its worktree path
  git-recent list            colorful recent branch list
  git-recent list --no-color plain recent branch list
  git-recent help

Order:
  Branches first appear by HEAD reflog checkout/switch history, newest first.
  For each switch, the branch you just left is shown before the destination.
  The picker omits the current branch; list includes it with a * marker.
  Local branches not found in checkout history are appended by tip commit date.

Notes:
  This is local history. Reflog entries can expire and are not shared with remotes.
  Install fzf for arrow-key selection; without it, git-recent uses numbered prompts.
EOF
}

main() {
  local cmd="${1:-pick}"
  [[ $# -gt 0 ]] && shift || true
  case "$cmd" in
    pick|checkout|switch) cmd_pick "$@" ;;
    list|ls) cmd_list "$@" ;;
    help|-h|--help) cmd_help ;;
    *) die "unknown command: $cmd (try: git-recent help)" ;;
  esac
}

main "$@"
