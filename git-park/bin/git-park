#!/usr/bin/env bash
# Park uncommitted work on a linked worktree and switch the main clone to main.
# State: wip-worktree-last, wip-save-history (git common dir). See ~/utility/git-park/README.md.
set -euo pipefail

STATE_NAME="wip-worktree-last"
HISTORY_NAME="wip-save-history"
DEFAULT_ROOT="${WIP_WORKTREE_ROOT:-$HOME/git-worktrees}"

die() { echo "git-park: $*" >&2; exit 1; }

have_tty() { [[ -t 0 || -t 1 || -t 2 ]] && [[ -r /dev/tty ]]; }

have_fzf() { command -v fzf >/dev/null 2>&1; }

repo_root() { git rev-parse --show-toplevel 2>/dev/null; }

git_common_dir() {
  git rev-parse --path-format=absolute --git-common-dir 2>/dev/null
}

is_primary_worktree() {
  local gd cd_
  gd="$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)" || return 1
  cd_="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
  [[ "$gd" == "$cd_" ]]
}

current_branch_name() {
  git branch --show-current 2>/dev/null || echo "(detached)"
}

# Print context when cwd is a linked worktree (not the primary checkout).
hint_linked_worktree_if_needed() {
  [[ -n "${GIT_PARK_HINTED_LINKED:-}" ]] && return 0
  local root br
  root="$(repo_root 2>/dev/null)" || return 0
  [[ -n "$root" ]] || return 0
  is_primary_worktree && return 0
  br="$(current_branch_name)"
  GIT_PARK_HINTED_LINKED=1
  export GIT_PARK_HINTED_LINKED
  echo "" >&2
  echo "git-park: You’re in a linked worktree → $(printf '%q' "$root") (branch ${br})." >&2
  echo "  After \`park\`, your WIP is usually already in this directory — use git status." >&2
  echo "  Stashes are often empty here (stash was popped when the worktree was created)." >&2
  echo "  Run \`park\` again only from the primary clone (checkout on main/master)." >&2
  echo "  Back to primary clone: cd \"\$(git park home)\"" >&2
  echo "" >&2
}

copy_shell_line_to_clipboard() {
  local line="$1"
  if command -v wl-copy >/dev/null 2>&1 && printf '%s' "$line" | wl-copy 2>/dev/null; then return 0; fi
  if command -v xclip >/dev/null 2>&1 && printf '%s' "$line" | xclip -selection clipboard 2>/dev/null; then return 0; fi
  if command -v xsel >/dev/null 2>&1 && printf '%s' "$line" | xsel --clipboard 2>/dev/null; then return 0; fi
  if command -v pbcopy >/dev/null 2>&1 && printf '%s' "$line" | pbcopy 2>/dev/null; then return 0; fi
  return 1
}

default_integration_branch() {
  if git show-ref --verify --quiet refs/heads/main; then echo main; return; fi
  if git show-ref --verify --quiet refs/heads/master; then echo master; return; fi
  git symbolic-ref -q refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo main
}

sanitize() {
  local s="$1"
  s="${s//\//-}"
  s="${s//[^a-zA-Z0-9._-]/_}"
  echo "$s"
}

state_file() {
  local cd_
  cd_="$(git_common_dir)" || die "not inside a git repository"
  echo "$cd_/$STATE_NAME"
}

history_file() {
  local cd_
  cd_="$(git_common_dir)" || die "not inside a git repository"
  echo "$cd_/$HISTORY_NAME"
}

append_history_line() {
  local worktree_path="$1" branch="$2" integration="$3" had_stash="$4"
  local hf d
  hf="$(history_file)"
  d="$(date -Iseconds 2>/dev/null || date)"
  # TAB-separated; paths should not contain TAB
  printf '%s\t%s\t%s\t%s\t%s\n' "$d" "$worktree_path" "$branch" "$integration" "$had_stash" >>"$hf"
  chmod 600 "$hf" 2>/dev/null || true
}

write_state() {
  local worktree_path="$1" branch="$2" integration="$3" had_stash="$4"
  local f
  f="$(state_file)"
  umask 077
  cat >"$f" <<EOF
# Written by git-park — safe to delete
WORKTREE_PATH=$worktree_path
BRANCH=$branch
INTEGRATION_BRANCH=$integration
HAD_STASH=$had_stash
DATE=$(date -Iseconds 2>/dev/null || date)
EOF
  echo "Recorded: $f"
  append_history_line "$worktree_path" "$branch" "$integration" "$had_stash"
}

# Pick one line from arguments; prints selection to stdout. Returns 1 on cancel / empty.
pick_from_strings() {
  local header="$1"
  shift
  [[ $# -gt 0 ]] || return 1
  if have_fzf && have_tty; then
    printf '%s\n' "$@" | fzf \
      --height=14 \
      --layout=reverse \
      --border=rounded \
      --header="$header" \
      --prompt="> "
  else
    echo "" >&2
    echo "git-park: $header" >&2
    echo "(Install fzf for arrow-key selection: https://github.com/junegunn/fzf)" >&2
    echo "" >&2
    local i=1 opt
    for opt in "$@"; do
      echo "  $i) $opt" >&2
      ((i++)) || true
    done
    echo "  0) Cancel" >&2
    local n
    have_tty || { echo "git-park: interactive selection needs a terminal" >&2; return 1; }
    read -r -p "Enter number [0=cancel]: " n </dev/tty || return 1
    [[ -n "${n:-}" ]] || return 1
    [[ "$n" == "0" ]] && return 1
    if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= $# )); then
      eval "printf '%s\n' \"\${$n}\""
    else
      echo "git-park: invalid selection" >&2
      return 1
    fi
  fi
}

confirm_remove_with_force() {
  local target="$1"
  local header=$'Worktree has modified or untracked files.\nRemoving it with --force may discard uncommitted changes.\n'
  header+="Path: $target"

  if have_fzf && have_tty; then
    local choice
    choice="$(printf '%s\n' "Cancel" "Force remove" | fzf \
      --height=8 \
      --layout=reverse \
      --border=rounded \
      --header="$header" \
      --prompt="> ")" || return 1
    [[ "$choice" == "Force remove" ]]
    return
  fi

  local yn
  echo "" >&2
  echo "git-park: worktree has modified or untracked files:" >&2
  echo "  $target" >&2
  echo "Removing it with --force may discard uncommitted changes." >&2
  have_tty || { echo "git-park: cannot prompt without a terminal; rerun with --force if you are sure" >&2; return 1; }
  read -r -p "Force remove this worktree? [y/N] " yn </dev/tty || return 1
  [[ "${yn:-}" == [yY] ]] || [[ "${yn:-}" == [yY][eE][sS] ]]
}

worktree_has_uncommitted_changes() {
  local target="$1"
  [[ -d "$target" ]] || return 1
  [[ -d "$target/.git" || -f "$target/.git" ]] || return 1
  [[ -n "$(git -C "$target" status --porcelain --untracked-files=all 2>/dev/null || true)" ]]
}

# --- park: shared precheck + execution ---

# Returns 0 and sets PARK_* vars, or returns 1 and prints reason to stderr.
park_precheck_inner() {
  PARK_ROOT="$(repo_root)" || { echo "git-park: not inside a git repository" >&2; return 1; }
  if ! is_primary_worktree; then
    echo "git-park: you’re in a linked worktree — \`park\` only runs from the primary clone" >&2
    echo "  (the checkout whose .git is a directory, not a file). cd there and try again." >&2
    return 1
  fi
  local here
  here="$(pwd -P)"
  if [[ "$here" != "$PARK_ROOT"/* && "$here" != "$PARK_ROOT" ]]; then
    echo "git-park: run from inside the repository (repo root: $PARK_ROOT)" >&2
    return 1
  fi

  PARK_BRANCH="$(git -C "$PARK_ROOT" branch --show-current 2>/dev/null)" || true
  if [[ -z "${PARK_BRANCH:-}" ]]; then
    echo "git-park: detached HEAD — checkout a branch before parking" >&2
    return 1
  fi

  if [[ -n "${PARK_INTEGRATION_OVERRIDE:-}" ]]; then
    PARK_INTEGRATION="$PARK_INTEGRATION_OVERRIDE"
  else
    PARK_INTEGRATION="$(default_integration_branch)"
  fi
  if [[ "$PARK_BRANCH" == "$PARK_INTEGRATION" ]]; then
    echo "git-park: on '$PARK_INTEGRATION' — checkout your feature branch first" >&2
    return 1
  fi

  PARK_REPO_BASE="$(basename "$PARK_ROOT")"
  PARK_SAFE_BRANCH="$(sanitize "$PARK_BRANCH")"
  PARK_DEFAULT_WT="$DEFAULT_ROOT/${PARK_REPO_BASE}-${PARK_SAFE_BRANCH}"

  local dirty
  dirty="$(git -C "$PARK_ROOT" status --porcelain)"
  if [[ -n "$dirty" ]]; then PARK_HAD_STASH=1; else PARK_HAD_STASH=0; fi
  return 0
}

park_precheck_or_die() {
  park_precheck_inner || exit 1
}

park_run() {
  local worktree_path="$1" msg_suffix="$2" dry_run="$3"
  local stash_msg="git-park: $msg_suffix"

  echo "Repo:       $PARK_ROOT"
  echo "WIP branch: $PARK_BRANCH"
  echo "This clone will checkout: $PARK_INTEGRATION"
  echo "Worktree:   $worktree_path"
  [[ "$PARK_HAD_STASH" -eq 1 ]] && echo "Stash:      yes (-u)" || echo "Stash:      (clean — skip stash/pop)"

  if [[ "$dry_run" -eq 1 ]]; then
    echo "[dry-run] no changes made"
    return 0
  fi

  mkdir -p "$(dirname "$worktree_path")"

  if [[ "$PARK_HAD_STASH" -eq 1 ]]; then
    git -C "$PARK_ROOT" stash push -u -m "$stash_msg"
  fi

  git -C "$PARK_ROOT" checkout "$PARK_INTEGRATION"

  if [[ -e "$worktree_path" ]]; then
    die "path already exists: $worktree_path — remove it or pass a different WORKTREE_PATH"
  fi

  git -C "$PARK_ROOT" worktree add "$worktree_path" "$PARK_BRANCH"

  if [[ "$PARK_HAD_STASH" -eq 1 ]]; then
    if git -C "$worktree_path" stash pop; then
      :
    else
      echo "git-park: stash pop reported conflicts or failed." >&2
      echo "  Worktree: $worktree_path" >&2
      echo "  Resolve conflicts, then: git stash drop (if pop left an entry)" >&2
      exit 1
    fi
  fi

  write_state "$worktree_path" "$PARK_BRANCH" "$PARK_INTEGRATION" "$PARK_HAD_STASH"

  echo
  echo "Done. Continue WIP in:"
  echo "  cd $(printf '%q' "$worktree_path")"
  echo "Reminder: git-park status  (from any worktree of this repo)" >&2
  echo "Jump to this WIP later: cd \"\$(git park go)\"" >&2
  echo "From linked worktree back to here: cd \"\$(git park home)\"" >&2
}

cmd_help() {
  cat <<'EOF'
git-park — park WIP in a second worktree; switch main clone to main

With git-park on your PATH, Git also accepts the same commands as:
  git park …                (same as git-park …)

Usage:
  git-park                  interactive menu (arrow keys if fzf installed)
  git-park park [OPTIONS] [WORKTREE_PATH]
  git-park remove [--pick|PATH] [--force]
  git-park restore          pick stash or saved worktree (interactive)
  git-park go [--pick] [PATH]   print path only — use: cd "$(git park go)"
  git-park home                 print primary clone path — use: cd "$(git park home)"
  git-park status
  git-park help

park:
  - Stashes with \`git stash push -u\` (saved: staged + unstaged + untracked; see \`git help stash\`).
  - Checks out the integration branch (main/master) in this clone.
  - Adds a linked worktree at WORKTREE_PATH for the branch you were on.
  - Pops the stash inside that worktree.
  - Saves WORKTREE_PATH and appends wip-save-history.

restore:
  - Stash: apply/pop affects the worktree that contains your cwd (repo root).
    After `park`, stashes are often already applied in the linked worktree — list may be empty.
  - Show cd: copy-pastable `cd`; active worktrees are sorted by recent use/touch,
    then saved history is appended (deduped by path).

go:
  - Prints **only** a directory path on stdout (for `cd "$(git park go)"`). Not a subprocess cd;
    your shell runs cd after reading the path.
  - Default: WORKTREE_PATH from wip-worktree-last. `--pick`: interactive list. Optional PATH argument.

home:
  - Prints **only** the **primary** (original) worktree path — the first entry Git reports (main clone).
  - Use `cd "$(git park home)"` from a linked worktree to jump back without remembering ~/Projects/.../embodik.

Options (park):
  -i, --integration BRANCH   Branch to leave this clone on (default: main or master)
  -m, --message TEXT         Stash message suffix (default: branch name + date)
  -n, --dry-run              Print what would happen; make no changes

Environment:
  WIP_WORKTREE_ROOT          Default parent dir when WORKTREE_PATH is omitted

UI:
  Install fzf for arrow-key menus. Without fzf, numbered prompts are used.

More: ~/utility/git-park/README.md
EOF
}

cmd_status() {
  local root sf hf
  root="$(repo_root)" || die "not inside a git repository"
  echo "=== worktrees (recently used/touched first) ==="
  local epoch dt path br disp label
  while IFS=$'\t' read -r epoch dt path br disp; do
    [[ -n "$path" ]] || continue
    label=""
    if [[ "$disp" == "[primary] "* ]]; then
      label=" [primary]"
    elif [[ "$disp" == "[last park] "* ]]; then
      label=" [last park]"
    fi
    if [[ -n "$br" ]]; then
      printf '%s  %s%s  [%s]\n' "$dt" "$path" "$label" "$br"
    else
      printf '%s  %s%s\n' "$dt" "$path" "$label"
    fi
  done < <(worktree_rows_recent)
  echo
  echo "=== stash list ==="
  git -C "$root" stash list || true
  sf="$(state_file)"
  if [[ -f "$sf" ]]; then
    echo
    echo "=== last park ($sf) ==="
    cat "$sf"
  else
    echo
    echo "(no $STATE_NAME yet — run \`git-park park\` once)"
  fi
  hf="$(history_file)"
  if [[ -f "$hf" ]]; then
    echo
    echo "=== recent park history (newest first, last 8) ==="
    if command -v tac >/dev/null 2>&1; then
      tac "$hf" | head -n 8
    else
      tac_fallback_reverse "$hf" | head -n 8
    fi
  fi
}

cmd_park() {
  local integration="" msg_suffix="" dry_run=0 worktree_path=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -i|--integration) integration="${2:-}"; shift 2 || die "missing value for $1";;
      -m|--message) msg_suffix="${2:-}"; shift 2 || die "missing value for $1";;
      -n|--dry-run) dry_run=1; shift;;
      -h|--help) cmd_help; exit 0;;
      -* ) die "unknown option: $1 (try: git-park help)";;
      *) worktree_path="$1"; shift; break;;
    esac
  done
  [[ $# -eq 0 ]] || die "unexpected arguments: $*"

  PARK_INTEGRATION_OVERRIDE="$integration"
  park_precheck_or_die
  unset PARK_INTEGRATION_OVERRIDE

  [[ -n "$worktree_path" ]] || worktree_path="$PARK_DEFAULT_WT"

  if [[ -z "$msg_suffix" ]]; then
    msg_suffix="$PARK_BRANCH $(date -Iminutes 2>/dev/null || date)"
  fi

  park_run "$worktree_path" "$msg_suffix" "$dry_run"
}

worktree_paths_porcelain() {
  local root
  root="$(repo_root)" || return 1
  git -C "$root" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print substr($0,10)}'
}

branch_timestamp_record() {
  local branch="$1" ts
  [[ -n "$branch" ]] || return 1
  ts="$(git reflog show --date=iso-strict --format='%ct%x09%cd' "$branch" 2>/dev/null | head -n 1 || true)"
  if [[ -n "$ts" ]]; then
    printf '%s\n' "$ts"
  else
    git log -1 --date=iso-strict --format='%ct%x09%cd' "$branch" 2>/dev/null || true
  fi
}

commit_timestamp_record() {
  local root="$1" ref="$2"
  git -C "$root" log -1 --date=iso-strict --format='%ct%x09%cd' "$ref" 2>/dev/null || true
}

# Git lists the primary (original) checkout first in porcelain — same as main clone path.
primary_worktree_path() {
  local root p
  root="$(repo_root)" || return 1
  p="$(git -C "$root" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print substr($0,10); exit}')"
  [[ -n "${p:-}" ]] || return 1
  printf '%s\n' "$p"
}

tac_fallback_reverse() {
  local f="$1"
  mapfile -t _hist_lines <"$f"
  local i
  for (( i=${#_hist_lines[@]}-1; i>=0; i-- )); do
    printf '%s\n' "${_hist_lines[i]}"
  done
}

_history_format_line() {
  local line="$1"
  [[ -n "$line" ]] || return 0
  IFS=$'\t' read -r dt path br int had <<<"$line" || true
  printf '[history %s] %s  (branch %s → %s)\n' "$dt" "$path" "$br" "$int"
}

# Normalize paths so /a/foo and /a/foo/ dedupe as the same option.
canonical_worktree_key() {
  local p="$1"
  [[ -z "$p" ]] && return 0
  if command -v realpath >/dev/null 2>&1; then
    realpath -m "$p" 2>/dev/null && return 0
  fi
  printf '%s\n' "${p%/}"
}

# Append display to opts if canonical path not in seen (namerefs: opts array, seen assoc).
wt_append_unique() {
  local -n _wu_opts="$1"
  local -n _wu_seen="$2"
  local disp="$3"
  local path="$4"
  local k
  [[ -z "$path" ]] && return 0
  k="$(canonical_worktree_key "$path")"
  [[ -z "$k" ]] && k="$path"
  [[ -n "${_wu_seen[$k]+x}" ]] && return 0
  _wu_seen[$k]=1
  _wu_opts+=("$disp")
}

worktree_display_label() {
  local path="$1" primary="$2" last_park="$3"
  local path_key primary_key="" last_key=""
  path_key="$(canonical_worktree_key "$path")"
  [[ -n "$primary" ]] && primary_key="$(canonical_worktree_key "$primary")"
  [[ -n "$last_park" ]] && last_key="$(canonical_worktree_key "$last_park")"

  if [[ -n "$primary_key" && "$path_key" == "$primary_key" ]]; then
    printf '[primary] %s\n' "$path"
  elif [[ -n "$last_key" && "$path_key" == "$last_key" ]]; then
    printf '[last park] %s\n' "$path"
  else
    printf '%s\n' "$path"
  fi
}

worktree_rows_recent() {
  local root primary lastp
  root="$(repo_root)" || return 1
  primary="$(primary_worktree_path 2>/dev/null || true)"
  lastp="$(last_park_worktree_path 2>/dev/null || true)"

  local rows
  rows="$(
    local path="" branch="" head="" line ts epoch date disp
    while IFS= read -r line; do
      if [[ "$line" == worktree\ * ]]; then
        if [[ -n "$path" ]]; then
          branch="${branch#refs/heads/}"
          if [[ -n "$branch" ]]; then
            ts="$(branch_timestamp_record "$branch")"
          else
            ts="$(commit_timestamp_record "$root" "$head")"
          fi
          if [[ -n "$ts" ]]; then
            IFS=$'\t' read -r epoch date <<<"$ts"
          else
            epoch=0
            date="-"
          fi
          disp="$(worktree_display_label "$path" "$primary" "$lastp")"
          printf '%s\t%s\t%s\t%s\t%s\n' "$epoch" "$date" "$path" "$branch" "$disp"
        fi
        path="${line#worktree }"
        branch=""
        head=""
        continue
      fi
      if [[ "$line" == HEAD\ * ]]; then
        head="${line#HEAD }"
        continue
      fi
      if [[ "$line" == branch\ * ]]; then
        branch="${line#branch }"
        continue
      fi
    done < <(git -C "$root" worktree list --porcelain 2>/dev/null)

    if [[ -n "$path" ]]; then
      branch="${branch#refs/heads/}"
      if [[ -n "$branch" ]]; then
        ts="$(branch_timestamp_record "$branch")"
      else
        ts="$(commit_timestamp_record "$root" "$head")"
      fi
      if [[ -n "$ts" ]]; then
        IFS=$'\t' read -r epoch date <<<"$ts"
      else
        epoch=0
        date="-"
      fi
      disp="$(worktree_display_label "$path" "$primary" "$lastp")"
      printf '%s\t%s\t%s\t%s\t%s\n' "$epoch" "$date" "$path" "$branch" "$disp"
    fi
  )"

  printf '%s\n' "$rows" | awk -F '\t' 'NF >= 5 { print }' | sort -rn -k1,1
}

# Display labels: "[last park] …", "[history …] …", or bare porcelain path.
extract_path_from_pick() {
  local s="$1"
  if [[ "$s" == "[primary] "* ]]; then
    printf '%s\n' "${s#"[primary] "}"
  elif [[ "$s" == "[last park] "* ]]; then
    printf '%s\n' "${s#"[last park] "}"
  elif [[ "$s" == '[history '* ]]; then
    s="${s#*] }"
    s="${s%%  (branch*}"
    printf '%s\n' "$s"
  else
    printf '%s\n' "$s"
  fi
}

# Parse "stash@{n}: …" (bash regex; avoids sed BRE issues across platforms).
parse_stash_ref_from_line() {
  local line="$1"
  if [[ "$line" =~ ^(stash@\{[0-9]+\}): ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  return 1
}

# Source WORKTREE_PATH= from wip-worktree-last if present.
last_park_worktree_path() {
  local sf p
  sf="$(state_file)"
  [[ -f "$sf" ]] || return 1
  p="$(grep '^WORKTREE_PATH=' "$sf" 2>/dev/null | sed 's/^WORKTREE_PATH=//')" || return 1
  [[ -n "$p" ]] || return 1
  printf '%s\n' "$p"
}

cmd_interactive_restore() {
  local root action
  if ! root="$(repo_root)" || [[ -z "$root" ]]; then
    echo "git-park: not inside a git repository — cd into a clone first." >&2
    return 0
  fi

  hint_linked_worktree_if_needed

  # In linked worktrees, stash is usually empty after park — put “show cd” first.
  if is_primary_worktree; then
    action="$(pick_from_strings "Restore — choose action" \
      "Apply or pop a stash (into this worktree’s checkout)" \
      "Show cd command (worktrees + saved parks — copy/paste into shell)" \
      "Back")" || return 0
  else
    action="$(pick_from_strings "Restore — linked worktree (stash often empty after park)" \
      "Show cd command (primary clone + other paths)" \
      "Apply or pop a stash (if you still have entries)" \
      "Back")" || return 0
  fi

  case "$action" in
    "Apply or pop a stash"*)
      cmd_restore_stash_picker "$root" || true
      ;;
    "Show cd command"*)
      cmd_restore_worktree_picker "$root" || true
      ;;
    Back*) return 0 ;;
    *) return 0 ;;
  esac
  return 0
}

cmd_restore_stash_picker() {
  local root="$1"
  local stashes=()
  mapfile -t stashes < <(git -C "$root" stash list 2>/dev/null) || true
  [[ ${#stashes[@]} -gt 0 ]] || {
    if is_primary_worktree; then
      echo "No stashes. After \`park\`, the stash was usually popped into the linked worktree — open that folder (Restore → Show cd) or check wip-worktree-last." >&2
    else
      echo "No stashes here — expected after \`park\` (stash was applied into this worktree when it was created)." >&2
      echo "Your WIP is this working tree: run git status. To park again, cd to the primary clone on main/master." >&2
    fi
    return 0
  }

  local pick
  pick="$(pick_from_strings "Pick a stash (↑↓ Enter, Esc cancel)" "${stashes[@]}")" || return 0

  local ref
  if ! ref="$(parse_stash_ref_from_line "$pick")"; then
    echo "git-park: could not parse stash ref from line — report this line: $pick" >&2
    return 0
  fi

  local how
  how="$(pick_from_strings "Apply keeps stash entry; pop removes it" "apply" "pop" "Cancel")" || return 0
  [[ "$how" == Cancel* ]] && return 0

  if [[ "$how" == "pop" ]]; then
    if ! git -C "$root" stash pop "$ref"; then
      echo "git-park: stash pop failed (conflicts or dirty tree?). Fix with git status, then retry." >&2
      return 0
    fi
    echo "OK: popped $ref into $(printf '%q' "$root")"
  else
    if ! git -C "$root" stash apply "$ref"; then
      echo "git-park: stash apply failed (conflicts or dirty tree?). Fix with git status, then retry." >&2
      return 0
    fi
    echo "OK: applied $ref into $(printf '%q' "$root")"
  fi
  return 0
}

list_non_primary_worktrees() {
  local root
  root="$(repo_root)" || return 1
  local first=1 cur_path="" cur_branch=""
  while IFS= read -r line; do
    if [[ "$line" == worktree\ * ]]; then
      if [[ -n "$cur_path" ]]; then
        if (( first == 0 )); then
          printf '%s\t%s\n' "$cur_path" "$cur_branch"
        fi
      fi
      cur_path="${line#worktree }"
      cur_branch=""
      if (( first == 1 )); then
        first=0
      fi
      continue
    fi
    if [[ "$line" == branch\ * ]]; then
      cur_branch="${line#branch }"
      continue
    fi
  done < <(git -C "$root" worktree list --porcelain 2>/dev/null)
  if [[ -n "$cur_path" ]]; then
    if (( first == 0 )); then
      printf '%s\t%s\n' "$cur_path" "$cur_branch"
    fi
  fi
}

cmd_remove() {
  local pick=0 force=0 explicit=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pick) pick=1; shift;;
      --force|-f) force=1; shift;;
      -h|--help)
        {
          printf '%s\n' 'git-park remove — remove a linked worktree (never the primary)'
          printf '%s\n' '' 'Examples:' \
            '  git park remove --pick          # choose a non-primary worktree to remove' \
            '  git park remove /path/to/wt     # remove that worktree (path must be an active worktree)' \
            '  git park rm --force --pick      # force-remove (like `git worktree remove -f`)' '' \
            'Defaults:' \
            '  If no PATH and no --pick are given, tries the last parked worktree path if it is an active worktree.'
        } >&2
        return 0
        ;;
      --) shift; break;;
      -* ) die "remove: unknown option: $1 (try: git-park remove --help)";;
      *) explicit="${1:-}"; shift; break;;
    esac
  done
  [[ $# -eq 0 ]] || die "remove: unexpected argument: $*"

  local root
  root="$(repo_root)" || { echo "git-park remove: not inside a git repository" >&2; return 1; }

  local -a paths=()
  local -A present=()
  local p br
  while IFS=$'\t' read -r p br; do
    [[ -n "$p" ]] || continue
    paths+=("$p")
    present["$(canonical_worktree_key "$p")"]=1
  done < <(list_non_primary_worktrees)

  if [[ ${#paths[@]} -eq 0 ]]; then
    echo "git-park remove: no non-primary worktrees to remove" >&2
    return 1
  fi

  local target=""
  if [[ -n "$explicit" ]]; then
    target="$explicit"
  elif (( pick == 1 )); then
    target="$(pick_from_strings "Pick worktree to remove (non-primary)" "${paths[@]}")" || return 1
  else
    target="$(last_park_worktree_path 2>/dev/null || true)"
    if [[ -z "${target:-}" ]]; then
      echo "git-park remove: no default path — use --pick or pass a PATH" >&2
      return 1
    fi
  fi

  target="$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' <<<"$target")"
  if command -v realpath >/dev/null 2>&1; then
    target="$(realpath -m "$target" 2>/dev/null || printf '%s\n' "$target")"
  fi

  local key
  key="$(canonical_worktree_key "$target")"

  if [[ -z "${present[$key]+x}" ]]; then
    echo "git-park remove: not an active non-primary worktree: $target" >&2
    echo "  Use --pick to choose from current worktrees." >&2
    return 1
  fi

  local primary
  primary="$(primary_worktree_path 2>/dev/null || true)"
  if [[ -n "${primary:-}" ]] && [[ "$(canonical_worktree_key "$primary")" == "$key" ]]; then
    echo "git-park remove: refusing to remove the primary worktree" >&2
    return 1
  fi

  echo "Removing worktree: $target" >&2
  local fflag=()
  (( force == 1 )) && fflag=( -f ) || true

  if [[ -d "$target" ]]; then
    if (( force == 0 )) && worktree_has_uncommitted_changes "$target"; then
      if confirm_remove_with_force "$target"; then
        fflag=(-f)
      else
        echo "git-park remove: cancelled" >&2
        return 1
      fi
    fi

    if ! remove_output="$(git -C "$root" worktree remove "${fflag[@]}" "$target" 2>&1)"; then
      echo "$remove_output" >&2
      if (( force == 0 )) && [[ "${fflag[*]:-}" != *"-f"* ]]; then
        echo "git-park remove: git worktree remove ${fflag[*]} $target failed. Use --force if needed." >&2
        return 1
      fi
      echo "git-park remove: git worktree remove ${fflag[*]} $target failed." >&2
      return 1
    fi
  else
    echo "Path not found on disk — attempting to prune stale worktree metadata…" >&2
    git -C "$root" worktree prune || true
  fi

  local sf lp
  sf="$(state_file 2>/dev/null || true)"
  lp="$(last_park_worktree_path 2>/dev/null || true)"
  if [[ -n "${sf:-}" ]] && [[ -f "$sf" ]] && [[ -n "${lp:-}" ]]; then
    if [[ "$(canonical_worktree_key "$lp")" == "$key" ]]; then
      rm -f -- "$sf" 2>/dev/null || true
      echo "Cleared last park file: $sf" >&2
    fi
  fi

  if [[ -d "$target" ]]; then
    echo "Note: directory still exists on disk (Git may have only detached it)." >&2
  else
    echo "Removed." >&2
  fi
  return 0
}

history_tsv_newest_first() {
  local hf="$1"
  [[ -f "$hf" ]] || return 0
  if command -v tac >/dev/null 2>&1; then
    tac "$hf"
  else
    tac_fallback_reverse "$hf"
  fi
}

# Fill option labels + dedupe keys. Args: name_of_opts_array name_of_seen_assoc (both empty from caller).
fill_worktree_pick_options() {
  local _opts_name="$1"
  local _seen_name="$2"
  local hf line dt path br int had disp epoch

  hf="$(history_file)"

  while IFS=$'\t' read -r epoch dt path br disp; do
    [[ -n "$path" ]] || continue
    wt_append_unique "$_opts_name" "$_seen_name" "$disp" "$path"
  done < <(worktree_rows_recent 2>/dev/null || true)

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    IFS=$'\t' read -r dt path br int had <<<"$line" || true
    [[ -z "$path" ]] && continue
    disp="$(_history_format_line "$line")"
    wt_append_unique "$_opts_name" "$_seen_name" "$disp" "$path"
  done < <(history_tsv_newest_first "$hf")
}

# stdout: single absolute path only. stderr: errors. For: cd "$(git park go)"
cmd_go() {
  local pick=0
  local explicit=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pick) pick=1; shift;;
      -h|--help)
        cat <<'EOF' >&2
git-park go — print worktree path for your shell to cd into

  cd "$(git park go)"              # last path from wip-worktree-last
  cd "$(git park go --pick)"       # choose from same list as Restore → Show cd
  cd "$(git park home)"            # primary (original) clone — use from a linked worktree

Optional explicit directory (must exist):
  cd "$(git park go /path/to/worktree)"

A subprocess cannot change your shell’s cwd; this prints only the path on stdout.
EOF
        return 0
        ;;
      --) shift; break;;
      -* ) die "go: unknown option: $1 (try: git-park go --help)";;
      *) explicit="${1:-}"; shift; break;;
    esac
  done
  [[ $# -eq 0 ]] || die "go: unexpected argument: $*"

  local root path pick_line
  root="$(repo_root)" || { echo "git-park go: not inside a git repository" >&2; return 1; }

  if [[ -n "$explicit" ]]; then
    path="$explicit"
  elif [[ "$pick" -eq 1 ]]; then
    local -a options=()
    local -A seen_paths=()
    fill_worktree_pick_options options seen_paths
    [[ ${#options[@]} -gt 0 ]] || { echo "git-park go: no worktrees or park history" >&2; return 1; }
    pick_line="$(pick_from_strings "git-park go — pick destination (↑↓ Enter)" "${options[@]}")" || return 1
    path="$(extract_path_from_pick "$pick_line")"
    [[ -n "$path" ]] || path="$pick_line"
  else
    path="$(last_park_worktree_path 2>/dev/null)" || true
    [[ -n "${path:-}" ]] || { echo "git-park go: no wip-worktree-last — run \`git-park park\` once or use --pick" >&2; return 1; }
  fi

  path="$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' <<<"$path")"
  if command -v realpath >/dev/null 2>&1; then
    path="$(realpath -m "$path" 2>/dev/null || printf '%s\n' "$path")"
  fi

  [[ -d "$path" ]] || { echo "git-park go: not a directory: $path" >&2; return 1; }
  printf '%s\n' "$path"
  return 0
}

# stdout: primary (main) worktree path only. stderr: errors. For: cd "$(git park home)"
cmd_home() {
  if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    cat <<'EOF' >&2
git-park home — print the primary (original) worktree path

  cd "$(git park home)"     # from a linked worktree, back to the main clone

Git lists the primary checkout first in `git worktree list`; this prints that path.
stdout is the directory only (same contract as `git park go`).
EOF
    return 0
  fi
  [[ $# -eq 0 ]] || die "home: unexpected argument: $1 (try: git-park home --help)"

  local path
  path="$(primary_worktree_path)" || {
    echo "git-park home: not in a git repository or could not read worktrees" >&2
    return 1
  }
  path="$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' <<<"$path")"
  if command -v realpath >/dev/null 2>&1; then
    path="$(realpath -m "$path" 2>/dev/null || printf '%s\n' "$path")"
  fi
  [[ -d "$path" ]] || { echo "git-park home: not a directory: $path" >&2; return 1; }
  printf '%s\n' "$path"
  return 0
}

cmd_restore_worktree_picker() {
  local root="$1"
  local -a options=()
  local -A seen_paths=()

  fill_worktree_pick_options options seen_paths

  [[ ${#options[@]} -gt 0 ]] || {
    echo "No worktrees or saved park history. Run \`git-park park\` once, or add a worktree manually." >&2
    return 0
  }

  local pick path lastp primary pkey lkey hkey
  pick="$(pick_from_strings "Pick path — copy the cd line below (↑↓ Enter)" "${options[@]}")" || return 0
  path="$(extract_path_from_pick "$pick")"
  [[ -n "$path" ]] || path="$pick"
  path="$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' <<<"$path")"

  local here cdline
  here="$(pwd -P)"
  cdline="cd $(printf '%q' "$path")"
  lastp="$(last_park_worktree_path 2>/dev/null || true)"
  primary="$(primary_worktree_path 2>/dev/null || true)"
  pkey="$(canonical_worktree_key "$path")"
  lkey=""
  hkey=""
  [[ -n "${lastp:-}" ]] && lkey="$(canonical_worktree_key "$lastp")"
  [[ -n "${primary:-}" ]] && hkey="$(canonical_worktree_key "$primary")"

  echo "" >&2
  if [[ "$here" == "$path" ]]; then
    echo "git-park: You’re already in this directory — no cd needed." >&2
    echo "  $(printf '%q' "$path")" >&2
    return 0
  fi

  echo "Shells can’t cd from a subprocess — paste this (or use clipboard if noted):" >&2
  echo
  echo "  $cdline"
  echo
  if [[ -n "$lkey" ]] && [[ "$pkey" == "$lkey" ]]; then
    echo "One-liner next time: cd \"\$(git park go)\"" >&2
  elif [[ -n "$hkey" ]] && [[ "$pkey" == "$hkey" ]]; then
    echo "One-liner next time: cd \"\$(git park home)\"" >&2
  else
    echo "One-liner (after this pick): cd \"\$(git park go --pick)\"" >&2
  fi
  echo "" >&2
  if copy_shell_line_to_clipboard "$cdline"; then
    echo "(also copied to clipboard)" >&2
  fi
  if [[ -d "$path" ]]; then
    echo "(directory exists)"
  else
    echo "(warning: path not found — remove stale worktree with: git worktree remove …)" >&2
  fi
  return 0
}

cmd_interactive_park() {
  PARK_INTEGRATION_OVERRIDE=""
  if ! park_precheck_inner; then
    echo "Park needs the primary clone on a feature branch (not main/master)." >&2
    echo "Tip: git switch <your-branch>  then run this again." >&2
    read -r -p "Press Enter…" </dev/tty || true
    return 0
  fi

  local wt msg
  wt="$PARK_DEFAULT_WT"
  echo "" >&2
  echo "Default worktree path:" >&2
  echo "  $wt" >&2
  read -r -e -p "Path [Enter = default]: " -i "$wt" wt_input </dev/tty || true
  wt="${wt_input:-$wt}"

  msg="$PARK_BRANCH $(date -Iminutes 2>/dev/null || date)"
  read -r -e -p "Stash message suffix [Enter = default]: " -i "$msg" msg_input </dev/tty || true
  msg="${msg_input:-$msg}"

  echo "" >&2
  park_run "$wt" "$msg" 1
  echo "" >&2
  local yn
  read -r -p "Proceed for real? [y/N] " yn </dev/tty || true
  if [[ "${yn:-}" == [yY] ]] || [[ "${yn:-}" == [yY][eE][sS] ]]; then
    park_run "$wt" "$msg" 0
  else
    echo "Cancelled." >&2
  fi
}

cmd_interactive() {
  hint_linked_worktree_if_needed

  local choice
  if ! choice="$(pick_from_strings "git-park — pick one (↑↓ Enter, Esc = cancel)" \
    "Park WIP (stash + worktree, checkout main here)" \
    "Restore (stash apply/pop or show cd to worktree)" \
    "Remove worktree" \
    "Status" \
    "Help" \
    "Quit")"; then
    echo "Cancelled."
    return 0
  fi

  case "$choice" in
    "Park WIP"*)
      if repo_root >/dev/null 2>&1; then
        cmd_interactive_park || true
      else
        echo "Not in a git repo. cd into your project first." >&2
      fi
      ;;
    "Restore"*)
      if repo_root >/dev/null 2>&1; then
        cmd_interactive_restore || true
      else
        echo "Not in a git repo." >&2
      fi
      ;;
    "Remove worktree"*)
      if repo_root >/dev/null 2>&1; then
        cmd_remove --pick || true
      else
        echo "Not in a git repo." >&2
      fi
      ;;
    Status)
      if repo_root >/dev/null 2>&1; then
        cmd_status || true
      else
        echo "Not in a git repo." >&2
      fi
      ;;
    Help)
      cmd_help
      ;;
    Quit*)
      echo "Bye."
      ;;
  esac
  return 0
}

main() {
  if [[ $# -eq 0 ]] || [[ "${1:-}" == "menu" ]] || [[ "${1:-}" == "i" ]] || [[ "${1:-}" == "interactive" ]]; then
    cmd_interactive
    exit 0
  fi

  local cmd="$1"
  shift || true
  case "$cmd" in
    park) cmd_park "$@" ;;
    remove|rm) cmd_remove "$@" ;;
    go) cmd_go "$@" ;;
    home) cmd_home "$@" ;;
    restore) cmd_interactive_restore || true ;;
    status) cmd_status ;;
    help|-h|--help) cmd_help ;;
    *) die "unknown command: $cmd — try: git-park help" ;;
  esac
}

main "$@"
