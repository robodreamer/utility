                border-radius: 8px;
                background: #172033;
                color: #ffffff;
                display: grid;
                place-items: center;
                font-weight: 700;
              }
              .brand-logo {
                width: 40px;
                height: 40px;
                border-radius: 10px;
              }
              .tool-grid {
                display: grid;
                grid-template-columns: minmax(280px, 360px) minmax(380px, 1fr) minmax(300px, 390px);
                gap: 14px;
                align-items: start;
              }
              .panel {
                background: #ffffff;
                border: 1px solid #dbe2ec;
                border-radius: 8px;
                box-shadow: 0 8px 24px rgba(25, 33, 52, 0.06);
                padding: 16px;
              }
              .section-title {
                color: #172033;
                font-size: 0.95rem;
                font-weight: 700;
                letter-spacing: 0;
              }
              .muted {
                color: #64748b;
