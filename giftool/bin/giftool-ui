try:
    from nicegui import app, events, ui
except ModuleNotFoundError as exc:
    missing = exc.name or "nicegui"
    print(
        f"{missing} is required for ClipFlip Studio.\n"
        "Install the UI dependencies with:\n"
        "  python3 -m pip install --user -r "
        f"{Path(__file__).resolve().parents[1] / 'requirements.txt'}",
        file=sys.stderr,
    )
    raise SystemExit(1) from exc


SCRIPT_DIR = Path(__file__).resolve().parent
ASSETS_DIR = SCRIPT_DIR.parent / "assets"
CACHE_DIR = Path(os.environ.get("GIFTOOL_UI_CACHE", str(Path.home() / ".cache" / "giftool-ui"))).expanduser()
UPLOAD_DIR = CACHE_DIR / "uploads"
OUTPUT_DIR = CACHE_DIR / "outputs"
FRAME_DIR = CACHE_DIR / "frames"
PREVIEW_DIR = CACHE_DIR / "previews"

VIDEO_SUFFIXES = {".mp4", ".m4v", ".mov", ".webm"}
GIF_SUFFIXES = {".gif"}
ACCEPTED_SUFFIXES = VIDEO_SUFFIXES | GIF_SUFFIXES
GIF_PREVIEW_MAX_FPS = 24.0
GIF_PREVIEW_MAX_FRAMES = 600
GIF_PLAYBACK_UI_FPS = 12.0
STATIC_FILE_URLS: dict[Path, str] = {}


def env_flag(name: str, default: bool = False) -> bool:
    raw_value = os.environ.get(name)
    if raw_value is None:
        return default
    return raw_value.lower() not in {"0", "false", "no", "off"}


def parse_window_size(value: str | None) -> tuple[int, int] | None:
    if not value:
        return None
    match = re.fullmatch(r"(\d+)x(\d+)", value.strip().lower())
    if not match:
        raise argparse.ArgumentTypeError("Use WIDTHxHEIGHT, for example 1280x900.")
    width, height = (int(match.group(1)), int(match.group(2)))
    if width <= 0 or height <= 0:
        raise argparse.ArgumentTypeError("Window dimensions must be positive.")
    return width, height


def parse_args(argv: list[str]) -> argparse.Namespace:
    env_port = os.environ.get("GIFTOOL_UI_PORT")
    parser = argparse.ArgumentParser(description="Launch the ClipFlip Studio UI.")
    parser.add_argument("--host", default=os.environ.get("GIFTOOL_UI_HOST", "127.0.0.1"))
    parser.add_argument("--port", type=int, default=int(env_port) if env_port else None)
    parser.add_argument("--no-show", action="store_true", default=not env_flag("GIFTOOL_UI_SHOW", True))
    parser.add_argument("--native", action="store_true", default=env_flag("GIFTOOL_UI_NATIVE", False))
    parser.add_argument(
        "--window-size",
        type=parse_window_size,
        default=parse_window_size(os.environ.get("GIFTOOL_UI_WINDOW_SIZE")),
        metavar="WIDTHxHEIGHT",
    )
    parser.add_argument("--fullscreen", action="store_true", default=env_flag("GIFTOOL_UI_FULLSCREEN", False))
    parser.add_argument("--frameless", action="store_true", default=env_flag("GIFTOOL_UI_FRAMELESS", False))
    return parser.parse_args(argv)


@dataclass
class MediaInfo:
    path: Path
    kind: str
    duration: float
    width: int | None
    height: int | None
    codec: str
    fps: float | None
    frame_count: str | None


@dataclass
class GifPreviewFile:
    start: float
    end: float
    path: Path


@dataclass
class GifPreviewFrame:
    start: float
    end: float
    path: Path
    url: str


def clean_filename(name: str) -> str:
    base = Path(name.replace("\x00", "")).name
    base = re.sub(r"[^A-Za-z0-9._ -]+", "_", base).strip(" .")
    return base or "upload"


def media_kind(path: Path) -> str:
    suffix = path.suffix.lower()
    if suffix in GIF_SUFFIXES:
        return "gif"
    if suffix in VIDEO_SUFFIXES:
        return "video"
    raise ValueError(f"Unsupported file type: {suffix or '(none)'}")


def parse_fraction(value: str | None) -> float | None:
    if not value or value == "0/0":
        return None
    if "/" in value:
        numerator, denominator = value.split("/", 1)
        try:
            den = float(denominator)
            return None if den == 0 else float(numerator) / den
        except ValueError:
            return None
    try:
        return float(value)
    except ValueError:
        return None


def format_seconds(value: float) -> str:
    if value < 60:
        return f"{value:.2f}s"
    minutes, seconds = divmod(value, 60)
    return f"{int(minutes)}m {seconds:05.2f}s"


def parse_number(value: Any, default: float = 0.0) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def probe_media(path: Path) -> MediaInfo:
    kind = media_kind(path)
    cmd = [
        "ffprobe",
        "-v",
        "error",
        "-show_entries",
        "format=duration:stream=codec_type,codec_name,width,height,avg_frame_rate,r_frame_rate,nb_frames",
        "-of",
        "json",
        str(path),
    ]
    result = subprocess.run(cmd, check=True, capture_output=True, text=True)
    payload = json.loads(result.stdout or "{}")

    stream = next(
        (item for item in payload.get("streams", []) if item.get("codec_type") == "video"),
        {},
    )
    duration = parse_number(payload.get("format", {}).get("duration"), 0.0)
    if duration <= 0 and kind == "gif":
        duration = probe_gif_duration(path)

    fps = parse_fraction(stream.get("avg_frame_rate")) or parse_fraction(stream.get("r_frame_rate"))
    return MediaInfo(
        path=path,
        kind=kind,
        duration=max(0.0, duration),
        width=stream.get("width"),
        height=stream.get("height"),
        codec=stream.get("codec_name") or "-",
        fps=fps,
        frame_count=stream.get("nb_frames"),
    )


def probe_gif_duration(path: Path) -> float:
    try:
        from PIL import Image, ImageSequence
    except ModuleNotFoundError:
        return 0.0

    total_ms = 0
    with Image.open(path) as image:
        for frame in ImageSequence.Iterator(image):
            total_ms += max(10, int(frame.info.get("duration", 100)))
    return total_ms / 1000.0


def extract_gif_preview_files(path: Path, total_duration: float = 0.0) -> list[GifPreviewFile]:
    try:
        from PIL import Image, ImageSequence
    except ModuleNotFoundError as exc:
        raise RuntimeError("Pillow is required for GIF frame preview.") from exc

    path = path.expanduser()
    FRAME_DIR.mkdir(parents=True, exist_ok=True)
    min_interval = 1.0 / GIF_PREVIEW_MAX_FPS
    if total_duration > 0:
        min_interval = max(min_interval, total_duration / GIF_PREVIEW_MAX_FRAMES)

    preview_files: list[GifPreviewFile] = []
    elapsed = 0.0
    last_saved_at = -min_interval
    mtime_ns = path.stat().st_mtime_ns
    safe_stem = clean_filename(path.stem)

    with Image.open(path) as image:
        for index, frame in enumerate(ImageSequence.Iterator(image)):
            duration = max(10, int(frame.info.get("duration", 100))) / 1000.0
            frame_start = elapsed
            frame_end = frame_start + duration
            should_save = not preview_files or frame_start - last_saved_at >= min_interval

            if should_save:
                target = FRAME_DIR / f"{safe_stem}-{mtime_ns}-{index}.png"
                if not target.exists():
                    frame.copy().convert("RGBA").save(target)
                preview_files.append(GifPreviewFile(frame_start, frame_end, target))
                last_saved_at = frame_start
            elif preview_files:
                preview_files[-1].end = frame_end

            elapsed = frame_end

    if not preview_files:
        raise RuntimeError("Could not read GIF frames.")
    return preview_files


def gif_video_preview_path(path: Path) -> Path:
    path = path.expanduser()
    return PREVIEW_DIR / f"{clean_filename(path.stem)}-{path.stat().st_mtime_ns}.mp4"


def ensure_gif_video_preview(path: Path) -> Path:
    target = gif_video_preview_path(path)
    if target.exists() and target.stat().st_size > 0:
        return target

    PREVIEW_DIR.mkdir(parents=True, exist_ok=True)
    temp_target = target.with_suffix(".tmp.mp4")
    cmd = [
        "ffmpeg",
        "-y",
        "-hide_banner",
        "-loglevel",
        "error",
        "-i",
        str(path.expanduser()),
        "-an",
        "-vf",
        "pad=ceil(iw/2)*2:ceil(ih/2)*2",
        "-pix_fmt",
        "yuv420p",
        "-movflags",
        "+faststart",
        str(temp_target),
    ]
    subprocess.run(cmd, check=True, capture_output=True, text=True)
    temp_target.replace(target)
    return target


def shell_join(cmd: list[str]) -> str:
    return " ".join(shlex.quote(part) for part in cmd)


def static_file_url(path: Path) -> str:
    resolved = path.resolve()
    if resolved not in STATIC_FILE_URLS:
        STATIC_FILE_URLS[resolved] = app.add_static_file(local_file=resolved)
    try:
        return f"{STATIC_FILE_URLS[resolved]}?v={resolved.stat().st_mtime_ns}"
    except OSError:
        return STATIC_FILE_URLS[resolved]


