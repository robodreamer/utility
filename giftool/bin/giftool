#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  giftool -i INPUT.gif -o OUTPUT.gif [options]

Options:
  -i, --input FILE        Input animated GIF
  -o, --output FILE       Output GIF
  -s, --start SECONDS     Start time in seconds
  -e, --end SECONDS       End time in seconds
  -d, --duration SECONDS  Duration in seconds
  -w, --width PIXELS      Output width, keeps aspect ratio if height omitted
  -h, --height PIXELS     Output height, keeps aspect ratio if width omitted
  -f, --fps FPS           Output frames per second
      --loop COUNT        GIF loop count, 0 means infinite
      --stats             Print ffmpeg progress
      --help              Show this help

Examples:
  giftool -i in.gif -o out.gif -s 1.2 -d 2.5 -w 480
  giftool -i in.gif -o out.gif -e 3.0 -h 240 -f 12
EOF
}

input=""
output=""
start=""
end=""
duration=""
width=""
height=""
fps=""
loop="0"
stats=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--input)
      input="${2:-}"; shift 2 ;;
    -o|--output)
      output="${2:-}"; shift 2 ;;
    -s|--start)
      start="${2:-}"; shift 2 ;;
    -e|--end)
      end="${2:-}"; shift 2 ;;
    -d|--duration)
      duration="${2:-}"; shift 2 ;;
    -w|--width)
      width="${2:-}"; shift 2 ;;
    -h|--height)
      height="${2:-}"; shift 2 ;;
    -f|--fps)
      fps="${2:-}"; shift 2 ;;
    --loop)
      loop="${2:-}"; shift 2 ;;
    --stats)
      stats="1"; shift ;;
    --help)
      usage; exit 0 ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1 ;;
  esac
done

if [[ -z "$input" || -z "$output" ]]; then
  usage >&2
  exit 1
fi

if [[ ! -f "$input" ]]; then
  echo "Input file not found: $input" >&2
  exit 1
fi

if [[ -n "$end" && -n "$duration" ]]; then
  echo "Use either --end or --duration, not both." >&2
  exit 1
fi

if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "ffmpeg is required but not found in PATH." >&2
  exit 1
fi

vf_parts=()

if [[ -n "$fps" ]]; then
  vf_parts+=("fps=${fps}")
fi

scale_w="-1"
scale_h="-1"
if [[ -n "$width" ]]; then
  scale_w="${width}"
fi
if [[ -n "$height" ]]; then
  scale_h="${height}"
fi
if [[ -n "$width" || -n "$height" ]]; then
  vf_parts+=("scale=${scale_w}:${scale_h}:flags=lanczos")
fi

if [[ ${#vf_parts[@]} -eq 0 ]]; then
  vf_chain="null"
else
  vf_chain="$(IFS=,; echo "${vf_parts[*]}")"
fi

ffmpeg_args=(-y)

if [[ -n "$start" ]]; then
  ffmpeg_args+=(-ss "$start")
fi

ffmpeg_args+=(-i "$input")

if [[ -n "$end" ]]; then
  ffmpeg_args+=(-to "$end")
fi

if [[ -n "$duration" ]]; then
  ffmpeg_args+=(-t "$duration")
fi

if [[ -z "$stats" ]]; then
  ffmpeg_args+=(-hide_banner -loglevel error)
fi

ffmpeg_args+=(
  -filter_complex
  "[0:v]${vf_chain},split[a][b];[a]palettegen=stats_mode=diff[p];[b][p]paletteuse=dither=sierra2_4a"
  -loop "$loop"
  "$output"
)

exec ffmpeg "${ffmpeg_args[@]}"
