#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  videotool -i INPUT.mp4 -o OUTPUT.mp4 [options]

Options:
  -i, --input FILE        Input video file
  -o, --output FILE       Output MP4 file
  -s, --start SECONDS     Start time in seconds
  -e, --end SECONDS       End time in seconds
  -d, --duration SECONDS  Duration in seconds
  -w, --width PIXELS      Output width, keeps aspect ratio if height omitted
  -h, --height PIXELS     Output height, keeps aspect ratio if width omitted
  -f, --fps FPS           Output frames per second
      --text TEXT         Burn one subtitle-style text overlay into the video
      --text-position POS top, center, or bottom; default bottom
      --text-size PIXELS  Text size for --text; default 36
      --compare FILE      Build a side-by-side comparison with another video
      --compare-start SEC Start time for the comparison video
      --compare-end SEC   End time for the comparison video
      --compare-duration SEC
                          Duration for the comparison video
      --label-left TEXT   Label for the left comparison panel
      --label-right TEXT  Label for the right comparison panel
      --label-size PIXELS Label text size; default 30
      --crf CRF           H.264 quality, lower is better; default 20
      --preset PRESET     H.264 preset; default medium
      --copy              Stream copy without re-encoding; ignores quality options
      --stats             Print ffmpeg progress
      --help              Show this help

Examples:
  videotool -i in.mp4 -o out.mp4 -s 4.2 -d 8.0
  videotool -i in.mp4 -o out.mp4 -e 12.0 -w 1280 --crf 22
  videotool -i in.mp4 -o clip.mp4 -s 30 -d 10 --copy
  videotool -i before.mp4 --compare after.mp4 -o side-by-side.mp4 -s 2 -d 10 --compare-start 1 --compare-duration 10 --label-left Before --label-right After
  videotool -i run.mp4 -o annotated.mp4 --text "model=v2, seed=42"
EOF
}

input=""
output=""
start=""
end=""
duration=""
width=""
height=""
fps=""
text=""
text_position="bottom"
text_size="36"
compare_input=""
compare_start=""
compare_end=""
compare_duration=""
label_left=""
label_right=""
label_size="30"
crf="20"
preset="medium"
copy_mode=""
stats=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--input)
      input="${2:-}"; shift 2 ;;
    -o|--output)
      output="${2:-}"; shift 2 ;;
    -s|--start)
      start="${2:-}"; shift 2 ;;
    -e|--end)
      end="${2:-}"; shift 2 ;;
    -d|--duration)
      duration="${2:-}"; shift 2 ;;
    -w|--width)
      width="${2:-}"; shift 2 ;;
    -h|--height)
      height="${2:-}"; shift 2 ;;
    -f|--fps)
      fps="${2:-}"; shift 2 ;;
    --text)
      text="${2:-}"; shift 2 ;;
    --text-position)
      text_position="${2:-}"; shift 2 ;;
    --text-size)
      text_size="${2:-}"; shift 2 ;;
    --compare)
      compare_input="${2:-}"; shift 2 ;;
    --compare-start)
      compare_start="${2:-}"; shift 2 ;;
    --compare-end)
      compare_end="${2:-}"; shift 2 ;;
    --compare-duration)
      compare_duration="${2:-}"; shift 2 ;;
    --label-left)
      label_left="${2:-}"; shift 2 ;;
    --label-right)
      label_right="${2:-}"; shift 2 ;;
    --label-size)
      label_size="${2:-}"; shift 2 ;;
    --crf)
      crf="${2:-}"; shift 2 ;;
    --preset)
      preset="${2:-}"; shift 2 ;;
    --copy)
      copy_mode="1"; shift ;;
    --stats)
      stats="1"; shift ;;
    --help)
      usage; exit 0 ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1 ;;
  esac
done

if [[ -z "$input" || -z "$output" ]]; then
  usage >&2
  exit 1
fi

if [[ ! -f "$input" ]]; then
  echo "Input file not found: $input" >&2
  exit 1
fi

if [[ -n "$compare_input" && ! -f "$compare_input" ]]; then
  echo "Compare input file not found: $compare_input" >&2
  exit 1
fi

if [[ -n "$end" && -n "$duration" ]]; then
  echo "Use either --end or --duration, not both." >&2
  exit 1
fi

if [[ -n "$compare_end" && -n "$compare_duration" ]]; then
  echo "Use either --compare-end or --compare-duration, not both." >&2
  exit 1
fi

if [[ -z "$compare_input" && ( -n "$compare_start" || -n "$compare_end" || -n "$compare_duration" ) ]]; then
  echo "Comparison trim options require --compare." >&2
  exit 1
fi

case "$text_position" in
  top|center|bottom) ;;
  *)
    echo "--text-position must be top, center, or bottom." >&2
    exit 1 ;;
esac

if [[ -n "$copy_mode" && ( -n "$width" || -n "$height" || -n "$fps" || -n "$text" || -n "$compare_input" ) ]]; then
  echo "--copy cannot be used with filters, text overlays, or comparison output." >&2
  exit 1
fi

if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "ffmpeg is required but not found in PATH." >&2
  exit 1
fi

if [[ -n "$compare_input" ]] && ! command -v ffprobe >/dev/null 2>&1; then
  echo "ffprobe is required for comparison duration matching but not found in PATH." >&2
  exit 1
fi

positive_difference() {
  local end_value="$1"
  local start_value="$2"
  local label="$3"
  awk -v end="$end_value" -v start="$start_value" -v label="$label" '
    BEGIN {
      duration = end - start
      if (duration <= 0) {
        printf "%s end time must be greater than start time.\n", label > "/dev/stderr"
        exit 1
      }
      printf "%.6f", duration
    }
  '
}

minimum_duration() {
  awk -v left="$1" -v right="$2" 'BEGIN { printf "%.6f", (left < right ? left : right) }'
}

probe_duration() {
  local file="$1"
  local value
  value="$(ffprobe -v error -show_entries format=duration -of default=nw=1:nk=1 "$file")"
  awk -v duration="$value" -v file="$file" '
    BEGIN {
      if (duration <= 0) {
        printf "Could not determine duration for %s.\n", file > "/dev/stderr"
        exit 1
      }
      printf "%.6f", duration
    }
  '
}

if [[ -n "$compare_input" ]]; then
  input_start="${start:-0}"
  if [[ -n "$duration" ]]; then
    input_trim_duration="$duration"
  elif [[ -n "$end" ]]; then
    input_trim_duration="$(positive_difference "$end" "$input_start" "Input")"
  else
    input_trim_duration="$(positive_difference "$(probe_duration "$input")" "$input_start" "Input")"
  fi

  compare_start_value="${compare_start:-0}"
  if [[ -n "$compare_duration" ]]; then
    compare_trim_duration="$compare_duration"
  elif [[ -n "$compare_end" ]]; then
    compare_trim_duration="$(positive_difference "$compare_end" "$compare_start_value" "Comparison")"
  else
    compare_trim_duration="$(positive_difference "$(probe_duration "$compare_input")" "$compare_start_value" "Comparison")"
  fi

  output_trim_duration="$(minimum_duration "$input_trim_duration" "$compare_trim_duration")"
  duration="$output_trim_duration"
  compare_duration="$output_trim_duration"
  end=""
  compare_end=""
fi

escape_drawtext() {
  local value="$1"
  value="${value//$'\n'/ }"
  value="${value//\\/\\\\}"
  value="${value//:/\\:}"
  value="${value//,/\\,}"
  value="${value//\'/\\\'}"
  value="${value//%/\\%}"
  printf '%s' "$value"
}

caption_filter() {
  local value="$1"
  local position="$2"
  local size="$3"
  local y_expr

  case "$position" in
    top)
      y_expr="32" ;;
    center)
      y_expr="(h-text_h)/2" ;;
    bottom)
      y_expr="h-text_h-32" ;;
  esac

  printf "drawtext=text='%s':x=(w-text_w)/2:y=%s:fontcolor=white:fontsize=%s:box=1:boxcolor=black@0.55:boxborderw=14" \
    "$(escape_drawtext "$value")" "$y_expr" "$size"
}

label_filter() {
  local value="$1"
  local size="$2"
  printf "drawtext=text='%s':x=28:y=28:fontcolor=white:fontsize=%s:box=1:boxcolor=black@0.55:boxborderw=10" \
    "$(escape_drawtext "$value")" "$size"
}

make_even() {
  local value="$1"
  echo $(( value / 2 * 2 ))
}

vf_parts=()

if [[ -n "$fps" ]]; then
  vf_parts+=("fps=${fps}")
fi

scale_w="-2"
scale_h="-2"
if [[ -n "$width" ]]; then
  scale_w="${width}"
fi
if [[ -n "$height" ]]; then
  scale_h="${height}"
fi
if [[ -n "$width" || -n "$height" ]]; then
  vf_parts+=("scale=${scale_w}:${scale_h}:flags=lanczos")
fi

if [[ -n "$text" ]]; then
  vf_parts+=("$(caption_filter "$text" "$text_position" "$text_size")")
fi

ffmpeg_args=(-y)

if [[ -n "$start" ]]; then
  ffmpeg_args+=(-ss "$start")
fi

if [[ -n "$compare_input" && -n "$duration" ]]; then
  ffmpeg_args+=(-t "$duration")
fi

ffmpeg_args+=(-i "$input")

if [[ -n "$compare_input" ]]; then
  if [[ -n "$compare_start" ]]; then
    ffmpeg_args+=(-ss "$compare_start")
  fi
  if [[ -n "$compare_duration" ]]; then
    ffmpeg_args+=(-t "$compare_duration")
  elif [[ -n "$compare_end" ]]; then
    ffmpeg_args+=(-to "$compare_end")
  fi
  ffmpeg_args+=(-i "$compare_input")
fi

if [[ -n "$end" ]]; then
  ffmpeg_args+=(-to "$end")
fi

if [[ -n "$duration" && -z "$compare_input" ]]; then
  ffmpeg_args+=(-t "$duration")
fi

if [[ -z "$stats" ]]; then
  ffmpeg_args+=(-hide_banner -loglevel error)
fi

if [[ -n "$copy_mode" ]]; then
  ffmpeg_args+=(
    -map 0
    -c copy
    -movflags +faststart
    "$output"
  )
elif [[ -n "$compare_input" ]]; then
  final_w="${width:-1920}"
  final_h="${height:-1080}"
  if [[ -n "$width" && -z "$height" ]]; then
    final_h=$(( width * 9 / 16 ))
  elif [[ -z "$width" && -n "$height" ]]; then
    final_w=$(( height * 16 / 9 ))
  fi
  final_w="$(make_even "$final_w")"
  final_h="$(make_even "$final_h")"
  panel_w="$(make_even $(( final_w / 2 )))"

  left_chain="scale=${panel_w}:${final_h}:force_original_aspect_ratio=decrease,pad=${panel_w}:${final_h}:(ow-iw)/2:(oh-ih)/2:color=black,setsar=1"
  right_chain="$left_chain"
  if [[ -n "$label_left" ]]; then
    left_chain+=",$(label_filter "$label_left" "$label_size")"
  fi
  if [[ -n "$label_right" ]]; then
    right_chain+=",$(label_filter "$label_right" "$label_size")"
  fi

  post_chain=""
  if [[ -n "$fps" ]]; then
    post_chain+=",fps=${fps}"
  fi
  if [[ -n "$text" ]]; then
    post_chain+=",$(caption_filter "$text" "$text_position" "$text_size")"
  fi

  filter_complex="[0:v]${left_chain}[left];[1:v]${right_chain}[right];[left][right]hstack=inputs=2:shortest=1${post_chain}[vout]"
  ffmpeg_args+=(
    -filter_complex "$filter_complex"
    -map "[vout]"
    -map 0:a?
    -c:v libx264
    -preset "$preset"
    -crf "$crf"
    -pix_fmt yuv420p
    -c:a aac
    -b:a 160k
    -shortest
    -movflags +faststart
    "$output"
  )
else
  if [[ ${#vf_parts[@]} -gt 0 ]]; then
    vf_chain="$(IFS=,; echo "${vf_parts[*]}")"
    ffmpeg_args+=(-vf "$vf_chain")
  fi

  ffmpeg_args+=(
    -map 0:v:0
    -map 0:a?
    -c:v libx264
    -preset "$preset"
    -crf "$crf"
    -pix_fmt yuv420p
    -c:a aac
    -b:a 160k
    -movflags +faststart
    "$output"
  )
fi

exec ffmpeg "${ffmpeg_args[@]}"
