#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ./install-deps [options]

Options:
      --user       Install Python packages with pip --user (default)
      --venv DIR   Create/use a virtualenv and install Python packages there
      --system     Install system packages with apt-get before Python packages
      --native     Install optional pywebview support for giftool-ui --native
      --no-links   Do not create ~/.local/bin command links
      --help       Show this help

Examples:
  ./install-deps
  ./install-deps --system
  ./install-deps --venv .venv
  ./install-deps --native
EOF
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
requirements="$script_dir/requirements.txt"
install_mode="user"
venv_dir=""
install_system=""
install_native=""
create_links="1"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --user)
      install_mode="user"; shift ;;
    --venv)
      install_mode="venv"
      venv_dir="${2:-}"
      shift 2 ;;
    --system)
      install_system="1"; shift ;;
    --native)
      install_native="1"; shift ;;
    --no-links)
      create_links=""; shift ;;
    --help)
      usage; exit 0 ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1 ;;
  esac
done

if [[ "$install_mode" == "venv" && -z "$venv_dir" ]]; then
  echo "--venv requires a directory." >&2
  exit 1
fi

if [[ -n "$install_system" ]]; then
  if ! command -v apt-get >/dev/null 2>&1; then
    echo "--system currently supports apt-get based Linux systems." >&2
    exit 1
  fi
  sudo apt-get update
  system_packages=(ffmpeg python3-pip python3-venv python3-tk)
  if [[ -n "$install_native" ]]; then
    system_packages+=(python3-gi python3-gi-cairo gir1.2-gtk-3.0 gstreamer1.0-plugins-bad)
    if apt-cache show gir1.2-webkit2-4.1 >/dev/null 2>&1; then
      system_packages+=(gir1.2-webkit2-4.1)
    elif apt-cache show gir1.2-webkit2-4.0 >/dev/null 2>&1; then
      system_packages+=(gir1.2-webkit2-4.0)
    fi
  fi
  sudo apt-get install -y "${system_packages[@]}"
fi

if ! command -v ffmpeg >/dev/null 2>&1; then
  cat >&2 <<'EOF'
ffmpeg was not found in PATH.

Install it with your system package manager, or rerun this script with:
  ./install-deps --system
EOF
  exit 1
fi

if ! command -v ffprobe >/dev/null 2>&1; then
  echo "ffprobe was not found in PATH. It is usually installed with ffmpeg." >&2
  exit 1
fi

if [[ "$install_mode" == "venv" ]]; then
  python3 -m venv "$venv_dir"
  "$venv_dir/bin/python" -m pip install --upgrade pip
  "$venv_dir/bin/python" -m pip install -r "$requirements"
  if [[ -n "$install_native" ]]; then
    "$venv_dir/bin/python" -m pip install pywebview
  fi
  python_cmd="$venv_dir/bin/python"
else
  python3 -m pip install --user --upgrade pip
  python3 -m pip install --user -r "$requirements"
  if [[ -n "$install_native" ]]; then
    python3 -m pip install --user pywebview
  fi
  python_cmd="python3"
fi

if [[ -n "$create_links" ]]; then
  mkdir -p "$HOME/.local/bin"
  ln -sf "$script_dir/bin/clipflip" "$HOME/.local/bin/clipflip"
  ln -sf "$script_dir/bin/clipflip-convert" "$HOME/.local/bin/clipflip-convert"
  ln -sf "$script_dir/bin/giftool" "$HOME/.local/bin/giftool"
  ln -sf "$script_dir/bin/videotool" "$HOME/.local/bin/videotool"
  ln -sf "$script_dir/bin/converttool" "$HOME/.local/bin/converttool"
  ln -sf "$script_dir/bin/giftool-ui" "$HOME/.local/bin/giftool-ui"
fi

cat <<EOF
Dependencies installed.

Run ClipFlip Studio with:
  clipflip
  clipflip --browser

Run the CLIs with:
  giftool --help
  videotool --help
  clipflip-convert --help

If clipflip is not found, add this to your shell profile:
  export PATH="\$HOME/.local/bin:\$PATH"

Python used for dependency checks:
  $python_cmd
EOF
